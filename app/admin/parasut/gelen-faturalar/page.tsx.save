"use client";

import Link from "next/link";
import { useEffect, useState } from "react";

export default function GelenFaturalarPage() {
  const [loading, setLoading] = useState(true);
  const [invoices, setInvoices] = useState<any[]>([]);
  const [message, setMessage] = useState("");

  async function loadInvoices() {
    try {
      setLoading(true);
      setMessage("");

      const res = await fetch(`/api/admin/parasut/gelen-faturalar?t=${Date.now()}`, {
        cache: "no-store",
      });

      const data = await res.json();

      if (!data.success) {
        setMessage("❌ Gelen faturalar alınamadı: " + JSON.stringify(data.error));
        return;
      }

      setInvoices(data.invoices || []);
    } catch (err) {
      setMessage("❌ Hata: " + String(err));
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    loadInvoices();
  }, []);

  return (
    <main className="min-h-screen bg-[#eef1ea] p-4 text-slate-900 md:p-6">
      <div className="mx-auto max-w-7xl space-y-5">
        <Link href="/admin" prefetch={false} className="font-black text-emerald-800">
          ← Admin Panel
        </Link>

        <section className="rounded-[32px] bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/10">
          <div className="flex flex-col justify-between gap-4 md:flex-row md:items-center">
            <div>
              <p className="text-xs font-black uppercase tracking-[0.24em] text-emerald-300">
                Paraşüt Entegrasyonu
              </p>
              <h1 className="mt-2 text-3xl font-black tracking-tight">
                Gelen Faturalar
              </h1>
              <p className="mt-2 text-sm text-white/60">
                Paraşüt gelen e-fatura kutusundaki faturaları listele.
              </p>
            </div>

            <button
              type="button"
              onClick={loadInvoices}
              disabled={loading}
              className="rounded-2xl bg-white px-5 py-3 text-sm font-black text-slate-950 disabled:opacity-50"
            >
              {loading ? "Yükleniyor..." : "Yenile"}
            </button>
          </div>

          {message && (
            <div className="mt-4 rounded-2xl bg-white/10 p-4 text-sm font-bold ring-1 ring-white/15">
              {message}
            </div>
          )}
        </section>

        <section className="rounded-[28px] bg-white p-4 shadow-sm ring-1 ring-slate-100">
          {loading ? (
            <div className="p-6 text-sm font-bold text-slate-500">
              Faturalar yükleniyor...
            </div>
          ) : invoices.length === 0 ? (
            <div className="p-8 text-center">
              <div className="text-4xl">📄</div>
              <h2 className="mt-4 text-xl font-black text-slate-950">
                Gelen fatura bulunamadı
              </h2>
              <p className="mt-2 text-sm text-slate-500">
                Paraşüt hesabında gelen fatura varsa burada listelenecek.
              </p>
            </div>
          ) : (
            <div className="space-y-2">
              {invoices.map((invoice) => {
                const attr = invoice.attributes || {};
                const supplier =
                  attr.sender_name ||
                  attr.contact_name ||
                  attr.name ||
                  attr.vkn ||
                  "-";

                const invoiceNo =
                  attr.invoice_id ||
                  attr.invoice_no ||
                  attr.document_no ||
                  invoice.id;

                const issueDate =
                  attr.issue_date ||
                  attr.invoice_date ||
                  attr.created_at ||
                  "-";

                const total =
                  attr.payable_amount ||
                  attr.total_amount ||
                  attr.net_total ||
                  "-";

                const status = attr.status || attr.invoice_status || "-";

                return (
                  <div
                    key={invoice.id}
                    className="grid gap-3 rounded-2xl border border-slate-100 bg-slate-50 px-4 py-3 md:grid-cols-[1.2fr_1fr_1fr_1fr_120px] md:items-center"
                  >
                    <div className="min-w-0">
                      <p className="truncate text-sm font-black text-slate-950">
                        {supplier}
                      </p>
                      <p className="mt-1 text-xs font-semibold text-slate-500">
                        ID: {invoice.id}
                      </p>
                    </div>

                    <div>
                      <p className="text-[10px] font-bold uppercase text-slate-400">
                        Fatura No
                      </p>
                      <p className="text-sm font-black text-slate-800">
                        {invoiceNo}
                      </p>
                    </div>

                    <div>
                      <p className="text-[10px] font-bold uppercase text-slate-400">
                        Tarih
                      </p>
                      <p className="text-sm font-black text-slate-800">
                        {issueDate}
                      </p>
                    </div>

                    <div>
                      <p className="text-[10px] font-bold uppercase text-slate-400">
                        Tutar
                      </p>
                      <p className="text-sm font-black text-emerald-700">
                        {typeof total === "number" ? formatMoney(total) : total}
                      </p>
                    </div>

                    <div className="text-right">
                      <span className="rounded-full bg-white px-3 py-1 text-xs font-black text-slate-600 ring-1 ring-slate-200">
                        {status}
                      </span>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </section>
      </div>
    </main>
  );
}

function formatMoney(value: number) {
  return new Intl.NumberFormat("tr-TR", {
    style: "currency",
    currency: "TRY",
    maximumFractionDigits: 2,
  }).format(value || 0);
}


